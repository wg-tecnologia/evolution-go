# ===========================================
# CONFIGURAÇÃO DO SERVIDOR
# ===========================================

# Porta do servidor (padrão: 4000)
SERVER_PORT=4000

# Nome do cliente
CLIENT_NAME=evolution

# ===========================================
# SEGURANÇA - IMPORTANTE!
# ===========================================
# Gere uma chave API forte!
# Exemplo: openssl rand -hex 32
GLOBAL_API_KEY=SUA_CHAVE_API_AQUI

# ===========================================
# BANCO DE DADOS POSTGRESQL
# ===========================================
POSTGRES_AUTH_DB=postgresql://postgres:postgres@postgres:5432/evogo_auth?sslmode=disable
POSTGRES_USERS_DB=postgresql://postgres:postgres@postgres:5432/evogo_users?sslmode=disable

# Salvar mensagens no banco (true/false)
DATABASE_SAVE_MESSAGES=false

# ===========================================
# LOGS
# ===========================================
WADEBUG=INFO
LOGTYPE=console

# ===========================================
# CONEXÃO
# ===========================================
# Reconectar instâncias ao iniciar (true/false)
CONNECT_ON_STARTUP=false
